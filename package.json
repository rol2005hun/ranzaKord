{
  "name": "ranzakord",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "tauri": "tauri",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "eslint:check": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "typecheck": "nuxt typecheck",
    "fix": "pnpm run prettier:fix && pnpm run eslint:fix",
    "check": "pnpm run fix && pnpm run typecheck && pnpm run test --run",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "sync-boilerplate": "tsx sync-boilerplate.ts"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@unhead/vue": "^3.1.4",
    "jintr": "^3.3.1",
    "mongoose": "^9.7.0",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "pinia-orm": "^1.10.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "spotify-url-info": "^3.3.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@iconify-json/flag": "^1.2.12",
    "@iconify-json/fluent": "^1.2.49",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/hints": "1.1.2",
    "@nuxt/icon": "2.2.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.2.1",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/i18n": "10.4.0",
    "@nuxtjs/seo": "^5.3.0",
    "@pinia/colada-nuxt": "1.0.1",
    "@pinia/nuxt": "0.11.3",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/nuxt": "^14.3.0",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "^1.69.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxlint": "^1.69.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.4",
    "replace-in-file": "^8.4.0",
    "sass": "^1.101.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{vue,js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css,json}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@unhead/vue",
        "pinia",
        "@pinia/nuxt"
      ],
      "allowedVersions": {
        "@unhead/vue": "*",
        "pinia": "*",
        "@pinia/nuxt": "*"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
