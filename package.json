{
  "name": "ranzakord",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{vue,scss,css,js,ts,json}\"",
    "format:check": "prettier --check \"**/*.{vue,scss,css,js,ts,json}\"",
    "typecheck": "nuxt typecheck",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "sync-boilerplate": "tsx sync-boilerplate.ts"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.1",
    "@unhead/vue": "^3.1.0",
    "mongoose": "^9.6.2",
    "nuxt": "^4.4.6",
    "pinia": "^3.0.4",
    "pinia-orm": "^1.10.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@iconify-json/flag": "^1.2.12",
    "@iconify-json/fluent": "^1.2.48",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/hints": "1.1.2",
    "@nuxt/icon": "2.2.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.1.1",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/i18n": "10.4.0",
    "@nuxtjs/seo": "^5.1.3",
    "@pinia/colada-nuxt": "1.0.1",
    "@pinia/nuxt": "0.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/nuxt": "^14.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "oxlint": "^1.66.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@unhead/vue",
        "pinia",
        "@pinia/nuxt"
      ],
      "allowedVersions": {
        "@unhead/vue": "*",
        "pinia": "*",
        "@pinia/nuxt": "*"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
